{
  "realm": "rucio",
  "enabled": true,
  "accessTokenLifespan": 3600,
  "refreshTokenMaxReuse": 1,
  "roles": {
    "realm": [
      { "name": "offline_access", "description": "Role for creating offline tokens" }
    ]
  },
  "groups": [
    {
      "name": "rucio",
      "path": "/rucio",
      "subGroups": [
        { "name": "admins", "path": "/rucio/admins" },
        { "name": "users", "path": "/rucio/users" }
      ]
    },
    {
      "name": "atlas",
      "path": "/atlas",
      "subGroups": [
        { "name": "production", "path": "/atlas/production" },
        { "name": "users", "path": "/atlas/users" }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "rucio",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "rucio-secret",
      "publicClient": false,
      "redirectUris": [
        "http://rucio/auth/oidc_token",
        "http://rucio/auth/oidc_code",
        "http://rucio/auth/oidc_redirect"
      ],
      "standardFlowEnabled": true,
      "serviceAccountsEnabled": true,
      "directAccessGrantsEnabled": true,
      "fullScopeAllowed": true,
      "defaultClientScopes": [
        "wlcg", "fts",
        "storage.read", "storage.modify",
        "storage.read:/data", "storage.modify:/data",
        "storage.read:/", "storage.modify:/"
      ],
      "optionalClientScopes": [
        "offline_access",
        "aud:fts", "aud:xrd3", "aud:xrd4",
        "aud:teapot1", "aud:teapot2", "aud:rucio"
      ],
      "attributes": {
        "oidc.ciba.grant.enabled": "false",
        "oauth2.device.authorization.grant.enabled": "false",
        "backchannel.logout.session.required": "true",
        "backchannel.logout.revoke.offline.tokens": "false",
        "token.exchange.standard.flow.enabled": "true",
        "can.delegate.tokens": "true"
      }
    },
    {
      "clientId": "fts",
      "enabled": true,
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "fts-secret",
      "serviceAccountsEnabled": true,
      "defaultClientScopes": [
        "wlcg", "fts",
        "storage.read", "storage.modify",
        "storage.read:/data", "storage.modify:/data",
        "storage.read:/", "storage.modify:/"
      ],
      "optionalClientScopes": [
        "offline_access",
        "aud:fts", "aud:xrd3", "aud:xrd4",
        "aud:teapot1", "aud:teapot2"
      ],
      "attributes": {
        "token.exchange.standard.flow.enabled": "true",
        "can.delegate.tokens": "true"
      }
    },
    {
      "clientId": "xrd3",
      "name": "xrd3 storage endpoint (token-exchange audience target)",
      "description": "Registered so FTS token-exchange requests carrying audience=xrd3 resolve to a client. Not used for interactive login.",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "xrd3-secret",
      "publicClient": false,
      "bearerOnly": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": false,
      "defaultClientScopes": [ "aud:xrd3" ],
      "optionalClientScopes": [],
      "attributes": {
        "token.exchange.standard.flow.enabled": "true"
      }
    },
    {
      "clientId": "xrd4",
      "name": "xrd4 storage endpoint (token-exchange audience target)",
      "description": "Registered so FTS token-exchange requests carrying audience=xrd4 resolve to a client. Not used for interactive login.",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "xrd4-secret",
      "publicClient": false,
      "bearerOnly": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": false,
      "defaultClientScopes": [ "aud:xrd4" ],
      "optionalClientScopes": [],
      "attributes": {
        "token.exchange.standard.flow.enabled": "true"
      }
    },
    {
      "clientId": "teapot1",
      "name": "teapot1 storage endpoint (token-exchange audience target)",
      "description": "Registered so FTS token-exchange requests carrying audience=teapot1 resolve to a client. Not used for interactive login.",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "teapot1-secret",
      "publicClient": false,
      "bearerOnly": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": false,
      "defaultClientScopes": [ "aud:teapot1" ],
      "optionalClientScopes": [],
      "attributes": {
        "token.exchange.standard.flow.enabled": "true"
      }
    },
    {
      "clientId": "teapot2",
      "name": "teapot2 storage endpoint (token-exchange audience target)",
      "description": "Registered so FTS token-exchange requests carrying audience=teapot2 resolve to a client. Not used for interactive login.",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "teapot2-secret",
      "publicClient": false,
      "bearerOnly": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": false,
      "defaultClientScopes": [ "aud:teapot2" ],
      "optionalClientScopes": [],
      "attributes": {
        "token.exchange.standard.flow.enabled": "true"
      }
    }
  ],
  "users": [
    {
      "username": "randomaccount",
      "id": "33ec5a95-4955-484d-9b21-818e19a8d749",
      "enabled": true,
      "firstName": "Random",
      "lastName": "Account",
      "email": "randomaccount@rucio",
      "emailVerified": true,
      "requiredActions": [],
      "realmRoles": [ "offline_access" ],
      "credentials": [
        { "type": "password", "value": "secret", "temporary": false }
      ],
      "groups": [ "/rucio/users", "/atlas/users" ]
    },
    {
      "username": "adminuser",
      "enabled": true,
      "firstName": "Admin",
      "lastName": "User",
      "email": "admin@rucio",
      "emailVerified": true,
      "requiredActions": [],
      "realmRoles": [ "offline_access" ],
      "credentials": [
        { "type": "password", "value": "admin123", "temporary": false }
      ],
      "groups": [ "/rucio/admins", "/atlas/production" ]
    },
    {
      "username": "service-account-rucio",
      "id": "e8af11a6-76bb-44dd-abf7-32988c769cfc",
      "enabled": true,
      "email": "service-account-rucio@rucio",
      "serviceAccountClientId": "rucio"
    }
  ],
  "clientScopes": [
    {
      "name": "wlcg",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "wlcg-version",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "config": {
            "claim.name": "wlcg\\.ver",
            "claim.value": "1.0",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "userinfo.token.claim": "false"
          }
        },
        {
          "name": "nbf-patch",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "config": {
            "claim.name": "nbf",
            "claim.value": "1700000000",
            "jsonType.label": "long",
            "access.token.claim": "true"
          }
        },
        {
          "name": "wlcg-groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "config": {
            "claim.name": "wlcg\\.groups",
            "full.path": "true",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "userinfo.token.claim": "false"
          }
        }
      ]
    },
    { "name": "fts", "protocol": "openid-connect" },
    { "name": "storage.read", "protocol": "openid-connect" },
    { "name": "storage.modify", "protocol": "openid-connect" },
    { "name": "storage.read:/data", "protocol": "openid-connect" },
    { "name": "storage.modify:/data", "protocol": "openid-connect" },
    { "name": "storage.read:/", "protocol": "openid-connect" },
    { "name": "storage.modify:/", "protocol": "openid-connect" },

    {
      "name": "aud:fts",
      "description": "Adds fts to the token's aud claim. Request alongside 'fts' scope to get an FTS-submission token.",
      "protocol": "openid-connect",
      "attributes": {
        "display.on.consent.screen": "false",
        "include.in.token.scope": "false"
      },
      "protocolMappers": [
        {
          "name": "aud-fts",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.custom.audience": "fts",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    },
    {
      "name": "aud:teapot1",
      "description": "Adds teapot1 to the token's aud claim for Teapot validation.",
      "protocol": "openid-connect",
      "attributes": {
        "display.on.consent.screen": "false",
        "include.in.token.scope": "false"
      },
      "protocolMappers": [
        {
          "name": "aud-teapot1",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.custom.audience": "teapot1",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    },
    {
      "name": "aud:teapot2",
      "description": "Adds teapot2 to the token's aud claim for Teapot validation.",
      "protocol": "openid-connect",
      "attributes": {
        "display.on.consent.screen": "false",
        "include.in.token.scope": "false"
      },
      "protocolMappers": [
        {
          "name": "aud-teapot2",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.custom.audience": "teapot2",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    },
    {
      "name": "aud:xrd3",
      "description": "Adds xrd3 to the token's aud claim for SciTokens validation on xrd3.",
      "protocol": "openid-connect",
      "attributes": {
        "display.on.consent.screen": "false",
        "include.in.token.scope": "false"
      },
      "protocolMappers": [
        {
          "name": "aud-xrd3",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.custom.audience": "xrd3",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    },
    {
      "name": "aud:xrd4",
      "description": "Adds xrd4 to the token's aud claim for SciTokens validation on xrd4.",
      "protocol": "openid-connect",
      "attributes": {
        "display.on.consent.screen": "false",
        "include.in.token.scope": "false"
      },
      "protocolMappers": [
        {
          "name": "aud-xrd4",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.custom.audience": "xrd4",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    },
    {
     "name": "aud:rucio",
      "description": "Adds rucio to the token's aud claim. Required so a subject token satisfies the Rucio server's expected_audience gate in get_token_for_account_operation.",
      "protocol": "openid-connect",
      "attributes": {
        "display.on.consent.screen": "false",
        "include.in.token.scope": "false"
      },
      "protocolMappers": [
        {
          "name": "aud-rucio",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.custom.audience": "rucio",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    }
  ],
  "sslRequired": "none"
}
